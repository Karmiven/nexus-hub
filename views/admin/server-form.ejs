<%- include('../partials/header') %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

<section class="admin-header">
  <div class="container">
    <h1 class="page-title"><i data-lucide="settings"></i> <span data-i18n="<%= server ? 'admin_edit_server' : 'admin_new_server' %>"><%= server ? 'Редактировать' : 'Новый' %> сервер</span></h1>
    <%- include('../partials/admin-nav', { activeTab: 'servers' }) %>
  </div>
</section>

<section class="section container">
  <div class="form-card">
    <form action="<%= server ? '/admin/servers/' + server.id + '?_csrf=' + csrfToken : '/admin/servers?_csrf=' + csrfToken %>" method="POST" enctype="multipart/form-data" class="admin-form">
      <div class="form-row">
        <div class="form-group">
          <label for="name" data-i18n="admin_server_name">Название сервера *</label>
          <input type="text" id="name" name="name" class="form-input" required value="<%= server ? server.name : '' %>">
        </div>
        <div class="form-group">
          <label for="game" data-i18n="admin_server_game">Игра *</label>
          <input type="text" id="game" name="game" class="form-input" required value="<%= server ? server.game : '' %>" list="gamesList" placeholder="e.g. Minecraft, World of Warcraft">
          <datalist id="gamesList">
            <option value="Minecraft">
            <option value="World of Warcraft">
            <option value="Blade and Soul">
            <option value="Killing Floor 2">
            <option value="Counter-Strike 2">
            <option value="Valheim">
            <option value="ARK: Survival Evolved">
            <option value="Terraria">
          </datalist>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="ip" data-i18n="admin_server_ip">IP адрес *</label>
          <input type="text" id="ip" name="ip" class="form-input" required value="<%= server ? server.ip : '' %>" placeholder="e.g. 192.168.1.100">
        </div>
        <div class="form-group">
          <label for="port" data-i18n="admin_server_port">Порт *</label>
          <input type="number" id="port" name="port" class="form-input" required value="<%= server ? server.port : '' %>" min="1" max="65535" placeholder="e.g. 25565">
        </div>
      </div>
      <div class="form-group">
        <label for="description" data-i18n="admin_server_desc">Описание</label>
        <textarea id="description" name="description" class="form-input form-textarea" rows="4"><%= server ? server.description : '' %></textarea>
      </div>
      <div class="form-group">
        <label data-i18n="admin_server_image">Баннер сервера (необязательно)</label>
        <div class="image-section">
          <input type="file" id="imageFile" name="image" accept="image/*" style="display:none;">
          <div class="image-upload" id="imageUpload" style="<%= server && server.image ? 'display:none' : '' %>">
            <div class="upload-placeholder" style="padding:1.5rem;text-align:center;cursor:pointer;border:2px dashed var(--border);border-radius:var(--radius-sm);">
              <p><i data-lucide="image"></i> <span data-i18n="admin_server_image_click">Нажмите для загрузки баннера</span></p>
              <small style="color:var(--text-muted);" data-i18n="admin_image_hint_server">JPG, PNG, GIF, WebP (макс. 5MB) • 16:5</small>
            </div>
          </div>
          <input type="hidden" id="croppedImageData" name="croppedImageData">
          <div id="finalImagePreview" style="<%= server && server.image ? '' : 'display:none' %>">
            <img id="finalImage" src="<%= server && server.image ? server.image : '' %>" style="width:100%;max-height:150px;object-fit:cover;border-radius:var(--radius-sm);border:1px solid var(--border);">
            <div style="display:flex;gap:0.5rem;margin-top:0.75rem;">
              <button type="button" class="btn btn-xs btn-outline" id="recropBtn"><i data-lucide="crop"></i> <span data-i18n="admin_btn_crop">Обрезать</span></button>
              <button type="button" class="btn btn-xs btn-outline" id="replaceBtn"><i data-lucide="image-plus"></i> <span data-i18n="admin_btn_replace">Заменить</span></button>
              <button type="button" class="btn btn-xs btn-outline" style="color:var(--danger);border-color:var(--danger);" id="removeBtn"><i data-lucide="trash-2"></i> <span data-i18n="admin_btn_remove">Удалить</span></button>
            </div>
          </div>
        </div>
      </div>

      <fieldset class="form-fieldset">
        <legend data-i18n="admin_redirect_settings">Настройки редиректа</legend>
        <div class="form-group">
          <label class="checkbox-label">
            <input type="checkbox" name="redirect_enabled" value="1" id="redirectToggle" <%= server && server.redirect_enabled ? 'checked' : '' %>>
            <span data-i18n="admin_redirect_enable">Включить редирект при клике на сервер</span>
          </label>
        </div>
        <div class="form-group" id="redirectUrlGroup">
          <label for="redirect_url" data-i18n="admin_redirect_url">URL редиректа</label>
          <input type="url" id="redirect_url" name="redirect_url" class="form-input" value="<%= server ? server.redirect_url : '' %>" placeholder="https://example.com/launcher">
        </div>
      </fieldset>

      <fieldset class="form-fieldset">
        <legend data-i18n="admin_additional">Дополнительно</legend>
        <div class="form-group">
          <label class="checkbox-label">
            <input type="checkbox" name="show_player_count" value="1" <%= server && server.show_player_count ? 'checked' : '' %>>
            <span data-i18n="admin_show_players">Показывать кол-во игроков (только Minecraft)</span>
          </label>
        </div>
        <div class="form-group">
          <label class="checkbox-label">
            <input type="checkbox" name="show_ip_address" value="1" <%= !server || server.show_ip_address ? 'checked' : '' %>>
            <span data-i18n="admin_show_ip">Показывать IP адрес в списке серверов</span>
          </label>
        </div>
        <div class="form-group">
          <label for="sort_order" data-i18n="admin_sort_order">Порядок сортировки (меньше = выше)</label>
          <input type="number" id="sort_order" name="sort_order" class="form-input" value="<%= server ? server.sort_order : 0 %>" min="0">
        </div>
      </fieldset>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary" data-i18n="<%= server ? 'admin_save_server' : 'admin_add_server_btn' %>"><%= server ? 'Сохранить' : 'Добавить' %> сервер</button>
        <a href="/admin/servers" class="btn btn-outline" data-i18n="cancel">Отмена</a>
      </div>
    </form>
  </div>
</section>

<!-- Crop Modal -->
<div id="cropModal" class="modal" style="display:none;z-index:2000;">
  <div class="modal-content" style="max-width:600px;">
    <div class="modal-header">
      <h2><i data-lucide="crop"></i> <span data-i18n="admin_crop_banner_title">Обрезка баннера (16:5)</span></h2>
      <button type="button" class="modal-close" onclick="closeCropModal()">&times;</button>
    </div>
    <div style="max-height:400px;overflow:hidden;">
      <img id="cropperImage" style="max-width:100%;">
    </div>
    <div style="display:flex;gap:1rem;margin-top:1.5rem;justify-content:flex-end;">
      <button type="button" class="btn btn-secondary" onclick="closeCropModal()" data-i18n="cancel">Отмена</button>
      <button type="button" class="btn btn-primary" onclick="applyCrop()"><i data-lucide="check"></i> <span data-i18n="admin_btn_apply">Применить</span></button>
    </div>
  </div>
</div>

<script>
  // Redirect toggle
  var toggle = document.getElementById('redirectToggle');
  var urlGroup = document.getElementById('redirectUrlGroup');
  function updateRedirectVisibility() {
    urlGroup.style.display = toggle.checked ? 'block' : 'none';
  }
  toggle.addEventListener('change', updateRedirectVisibility);
  updateRedirectVisibility();

  // Image crop
  var imageUpload = document.getElementById('imageUpload');
  var imageFile = document.getElementById('imageFile');
  var finalPreview = document.getElementById('finalImagePreview');
  var finalImage = document.getElementById('finalImage');
  var cropModal = document.getElementById('cropModal');
  var cropper = null;
  var originalImageData = null;

  imageUpload.addEventListener('click', function(e) {
    if (e.target === imageFile) return;
    imageFile.click();
  });

  document.getElementById('replaceBtn').addEventListener('click', function() {
    imageFile.value = '';
    imageFile.click();
  });

  document.getElementById('recropBtn').addEventListener('click', function() {
    if (originalImageData) {
      openCropModal();
    } else if (finalImage.src) {
      var img = new Image();
      img.crossOrigin = 'anonymous';
      img.onload = function() {
        var canvas = document.createElement('canvas');
        canvas.width = img.naturalWidth;
        canvas.height = img.naturalHeight;
        canvas.getContext('2d').drawImage(img, 0, 0);
        originalImageData = canvas.toDataURL('image/jpeg', 1.0);
        openCropModal();
      };
      img.onerror = function() { alert(t('admin_image_load_error')); };
      img.src = finalImage.src;
    }
  });

  document.getElementById('removeBtn').addEventListener('click', function() {
    finalPreview.style.display = 'none';
    imageUpload.style.display = 'block';
    document.getElementById('croppedImageData').value = 'REMOVE';
    finalImage.src = '';
    originalImageData = null;
  });

  imageFile.addEventListener('change', function(e) {
    var file = e.target.files[0];
    if (!file) return;
    if (file.size > 5 * 1024 * 1024) { alert(t('admin_file_too_large')); return; }
    var reader = new FileReader();
    reader.onload = function(ev) {
      originalImageData = ev.target.result;
      openCropModal();
    };
    reader.readAsDataURL(file);
  });

  function openCropModal() {
    if (!originalImageData) return;
    var img = document.getElementById('cropperImage');
    img.src = originalImageData;
    if (cropper) cropper.destroy();
    cropper = new Cropper(img, {
      aspectRatio: 16 / 5,
      autoCropArea: 1,
      responsive: true,
      guides: true,
      center: true,
      highlight: true,
      cropBoxMovable: true,
      cropBoxResizable: true,
    });
    cropModal.style.display = 'flex';
  }

  function closeCropModal() { cropModal.style.display = 'none'; }

  function applyCrop() {
    if (!cropper) return;
    var canvas = cropper.getCroppedCanvas({
      maxWidth: 800,
      maxHeight: 250,
      fillColor: '#000',
      imageSmoothingEnabled: true,
      imageSmoothingQuality: 'high',
    });
    var croppedData = canvas.toDataURL('image/jpeg', 0.9);
    document.getElementById('croppedImageData').value = croppedData;
    finalImage.src = croppedData;
    finalPreview.style.display = 'block';
    imageUpload.style.display = 'none';
    closeCropModal();
    // Clear file input so form doesn't send raw file
    imageFile.value = '';
  }
</script>

<%- include('../partials/footer') %>
