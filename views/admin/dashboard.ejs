<%- include('../partials/header') %>

<section class="admin-header">
  <div class="container">
    <h1 class="page-title"><i data-lucide="settings"></i> <span data-i18n="admin_panel">Панель управления</span></h1>
    <nav class="admin-nav">
      <a href="/admin" class="admin-tab active" data-i18n="admin_tab_home">Главная</a>
      <a href="/admin/news" class="admin-tab" data-i18n="admin_tab_news">Новости</a>
      <a href="/admin/servers" class="admin-tab" data-i18n="admin_tab_servers">Сервера</a>
      <a href="/admin/users" class="admin-tab" data-i18n="admin_tab_users">Пользователи</a>
      <a href="/admin/settings" class="admin-tab" data-i18n="admin_tab_settings">Настройки</a>
      <a href="/admin/analytics" class="admin-tab" data-i18n="admin_tab_analytics">Аналитика</a>
      <a href="/admin/proxmox" class="admin-tab">Proxmox</a>
    </nav>
  </div>
</section>

<section class="section container">
  <!-- Stats Cards 4x2 -->
  <div class="stats-grid stats-grid-4x2">
    <div class="stat-card">
      <div class="stat-icon"><i data-lucide="newspaper"></i></div>
      <div class="stat-info">
        <span class="stat-number"><%= stats.newsCount %></span>
        <span class="stat-label" data-i18n="admin_stat_news">Новости</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon"><i data-lucide="gamepad-2"></i></div>
      <div class="stat-info">
        <span class="stat-number"><%= stats.totalServers %></span>
        <span class="stat-label" data-i18n="admin_stat_total_servers">Всего серверов</span>
      </div>
    </div>
    <div class="stat-card stat-card-online">
      <div class="stat-icon status-online"><i data-lucide="circle-check"></i></div>
      <div class="stat-info">
        <span class="stat-number"><%= stats.onlineServers %></span>
        <span class="stat-label" data-i18n="admin_stat_online_servers">Сервера онлайн</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon"><i data-lucide="users"></i></div>
      <div class="stat-info">
        <span class="stat-number"><%= stats.userCount %></span>
        <span class="stat-label" data-i18n="admin_stat_users">Пользователи</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon"><i data-lucide="eye"></i></div>
      <div class="stat-info">
        <span class="stat-number"><%= stats.totalViews %></span>
        <span class="stat-label" data-i18n="admin_stat_total_views">Просмотры</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon"><i data-lucide="trending-up"></i></div>
      <div class="stat-info">
        <span class="stat-number"><%= stats.todayViews %></span>
        <span class="stat-label" data-i18n="admin_stat_today_views">Сегодня</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon"><i data-lucide="message-square"></i></div>
      <div class="stat-info">
        <span class="stat-number"><%= stats.chatMessages %></span>
        <span class="stat-label" data-i18n="admin_stat_chat_msgs">Сообщения</span>
      </div>
    </div>
    <div class="stat-card stat-card-analytics-link" onclick="location.href='/admin/analytics'">
      <div class="stat-icon"><i data-lucide="bar-chart-3"></i></div>
      <div class="stat-info">
        <span class="stat-number" style="font-size:1rem;">&rarr;</span>
        <span class="stat-label" data-i18n="admin_tab_analytics">Аналитика</span>
      </div>
    </div>
  </div>

  <!-- Server Status Table -->
  <div class="admin-table-wrapper">
    <div class="admin-section-header">
      <h2 data-i18n="admin_server_monitor">Монитор статуса серверов</h2>
      <button type="button" id="refreshAllBtn" class="btn btn-sm btn-outline" onclick="refreshAllServers()"><i data-lucide="refresh-cw"></i> <span data-i18n="admin_refresh_all">Обновить все</span></button>
    </div>
    <div class="table-responsive">
      <table class="data-table table-dashboard">
        <thead>
          <tr>
            <th data-i18n="admin_th_name">Название</th>
            <th data-i18n="admin_th_game">Игра</th>
            <th data-i18n="admin_th_address">Адрес</th>
            <th data-i18n="admin_th_status">Статус</th>
            <th data-i18n="admin_th_checked">Проверено</th>
          </tr>
        </thead>
        <tbody>
          <% servers.forEach(function(srv) { %>
            <tr>
              <td><strong><%= srv.name %></strong></td>
              <td><%= srv.game %></td>
              <td class="mono"><%= srv.ip %>:<%= srv.port %></td>
              <td>
                <span class="status-badge badge-<%= srv.status %>">
                  <%= srv.status === 'online' ? 'Online' : 'Offline' %>
                </span>
              </td>
              <td><span class="local-time" data-timestamp="<%= srv.last_checked %>" data-format="datetime"></span></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<script>
async function refreshAllServers() {
  var btn = document.getElementById('refreshAllBtn');
  var token = document.querySelector('meta[name="csrf-token"]');
  btn.disabled = true;
  btn.querySelector('span').textContent = '...';
  try {
    var res = await fetch('/admin/servers/refresh', {
      method: 'POST',
      headers: {
        'X-Requested-With': 'XMLHttpRequest',
        'x-csrf-token': token ? token.content : ''
      }
    });
    var newToken = res.headers.get('X-CSRF-Token');
    if (newToken && token) token.setAttribute('content', newToken);
    var data = await res.json();
    if (data.success) {
      location.reload();
    } else {
      alert(data.message || 'Error');
      btn.disabled = false;
      btn.querySelector('span').textContent = (window.i18n ? window.i18n.t('admin_refresh_all') : 'Обновить все');
    }
  } catch(e) {
    alert('Failed to refresh');
    btn.disabled = false;
    btn.querySelector('span').textContent = (window.i18n ? window.i18n.t('admin_refresh_all') : 'Обновить все');
  }
}
</script>

<%- include('../partials/footer') %>
