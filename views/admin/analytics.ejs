<%- include('../partials/header') %>

<section class="admin-header">
  <div class="container">
    <h1 class="page-title"><i data-lucide="bar-chart-3"></i> <span data-i18n="admin_analytics_title">Аналитика</span></h1>
    <%- include('../partials/admin-nav', { activeTab: 'analytics' }) %>
  </div>
</section>

<section class="section container">
  <!-- Period selector -->
  <div class="admin-section-header" style="margin-bottom: 1.25rem;">
    <h2><i data-lucide="activity"></i> <span data-i18n="admin_analytics_overview">Обзор</span></h2>
    <div class="analytics-controls">
      <select id="analyticsDays" class="analytics-period-select">
        <option value="7" data-i18n="admin_period_7d">7 дней</option>
        <option value="14" selected data-i18n="admin_period_14d">14 дней</option>
        <option value="30" data-i18n="admin_period_30d">30 дней</option>
      </select>
      <button type="button" id="refreshChartsBtn" class="btn btn-sm btn-outline" onclick="loadAllCharts()">
        <i data-lucide="refresh-cw"></i> <span data-i18n="refresh">Обновить</span>
      </button>
    </div>
  </div>

  <!-- Charts Grid -->
  <div class="charts-grid">
    <!-- Page Views (Line) -->
    <div class="chart-card chart-card-wide">
      <div class="chart-header">
        <h3 data-i18n="admin_chart_pageviews">Просмотры страниц</h3>
      </div>
      <div class="chart-body" id="wrapPageViews">
        <div class="chart-loading">Loading...</div>
        <canvas id="chartPageViews"></canvas>
      </div>
    </div>

    <!-- Hourly Traffic (Bar) -->
    <div class="chart-card">
      <div class="chart-header">
        <h3 data-i18n="admin_chart_hourly">Трафик по часам</h3>
      </div>
      <div class="chart-body" id="wrapHourly">
        <div class="chart-loading">Loading...</div>
        <canvas id="chartHourly"></canvas>
      </div>
    </div>

    <!-- Popular Pages (Horizontal Bar) -->
    <div class="chart-card">
      <div class="chart-header">
        <h3 data-i18n="admin_chart_popular">Популярные страницы</h3>
      </div>
      <div class="chart-body" id="wrapPopular">
        <div class="chart-loading">Loading...</div>
        <canvas id="chartPopular"></canvas>
      </div>
    </div>

    <!-- Server Uptime (Bar) -->
    <div class="chart-card">
      <div class="chart-header">
        <h3 data-i18n="admin_chart_uptime">Аптайм серверов</h3>
      </div>
      <div class="chart-body" id="wrapUptime">
        <div class="chart-loading">Loading...</div>
        <canvas id="chartUptime"></canvas>
      </div>
    </div>

    <!-- Chat Activity (Bar) -->
    <div class="chart-card">
      <div class="chart-header">
        <h3 data-i18n="admin_chart_chat">Активность чата</h3>
      </div>
      <div class="chart-body" id="wrapChat">
        <div class="chart-loading">Loading...</div>
        <canvas id="chartChat"></canvas>
      </div>
    </div>

    <!-- Server Status Timeline (Stacked Area) -->
    <div class="chart-card chart-card-wide">
      <div class="chart-header">
        <h3 data-i18n="admin_chart_timeline">Статус серверов</h3>
      </div>
      <div class="chart-body" id="wrapTimeline">
        <div class="chart-loading">Loading...</div>
        <canvas id="chartTimeline"></canvas>
      </div>
    </div>

    <!-- Countries (Doughnut) -->
    <div class="chart-card">
      <div class="chart-header">
        <h3><i data-lucide="globe"></i> <span data-i18n="admin_chart_countries">Страны посетителей</span></h3>
      </div>
      <div class="chart-body" id="wrapCountries">
        <div class="chart-loading">Loading...</div>
        <canvas id="chartCountries"></canvas>
      </div>
    </div>

    <!-- Country Stats Table -->
    <div class="chart-card">
      <div class="chart-header">
        <h3><i data-lucide="flag"></i> <span data-i18n="admin_chart_by_country">По странам</span></h3>
      </div>
      <div class="chart-body" id="wrapCountryTable" style="overflow-y:auto; padding: 0;">
        <div class="chart-loading">Loading...</div>
        <table class="visitors-country-table" id="countryTable" style="display:none;">
          <thead><tr>
            <th data-i18n="admin_chart_country">Страна</th>
            <th data-i18n="admin_chart_visitors">Посетители</th>
            <th>%</th>
          </tr></thead>
          <tbody></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Visitor Log -->
  <div class="admin-table-wrapper" style="margin-top: 1.5rem;">
    <div class="admin-section-header">
      <h2><i data-lucide="users"></i> <span data-i18n="admin_visitor_log">Журнал посетителей</span></h2>
      <div class="analytics-controls">
        <button type="button" id="prevPageBtn" class="btn btn-sm btn-outline" disabled>&lt;</button>
        <span id="visitorPageInfo" style="color:var(--text-secondary);font-size:0.85rem;padding:0 0.5rem;">1 / 1</span>
        <button type="button" id="nextPageBtn" class="btn btn-sm btn-outline" disabled>&gt;</button>
      </div>
    </div>
    <div class="table-responsive">
      <table class="data-table visitor-log-table" id="visitorTable">
        <thead>
          <tr>
            <th class="sortable-th" data-sort="ip" style="width:12%"><span class="sort-wrap"><span data-i18n="admin_visitor_ip">IP</span><span class="sort-arrow"></span></span></th>
            <th class="sortable-th" data-sort="country" style="width:8%;text-align:center"><span class="sort-wrap"><span data-i18n="admin_visitor_country">Страна</span><span class="sort-arrow"></span></span></th>
            <th class="sortable-th" data-sort="visits" style="width:7%;text-align:center"><span class="sort-wrap"><span data-i18n="admin_visitor_visits">Визиты</span><span class="sort-arrow"></span></span></th>
            <th class="sortable-th" data-sort="pages" style="width:8%;text-align:center"><span class="sort-wrap"><span data-i18n="admin_visitor_pages">Страницы</span><span class="sort-arrow"></span></span></th>
            <th class="sortable-th" data-sort="first" style="width:13%"><span class="sort-wrap"><span data-i18n="admin_visitor_first">Первый визит</span><span class="sort-arrow"></span></span></th>
            <th class="sortable-th" data-sort="last" style="width:13%"><span class="sort-wrap"><span data-i18n="admin_visitor_last">Последний визит</span><span class="sort-arrow"></span></span></th>
            <th style="width:39%" data-i18n="admin_visitor_visited">Посещённые страницы</th>
          </tr>
        </thead>
        <tbody id="visitorTableBody">
          <tr><td colspan="7" style="text-align:center;color:var(--text-muted)">Loading...</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
.chart-loading {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  color: var(--text-muted); font-size: 0.85rem;
  background: var(--surface); z-index: 2;
}
.chart-no-data {
  position: absolute; inset: 0;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  color: var(--text-muted); font-size: 0.85rem; gap: 0.5rem;
  background: var(--surface); z-index: 2;
}
.chart-no-data i { width: 32px; height: 32px; opacity: 0.4; }
.chart-error {
  position: absolute; inset: 0;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  color: var(--danger, #ef4444); font-size: 0.8rem; gap: 0.35rem;
  background: var(--surface); z-index: 2;
}
.visitors-country-table { border: none; font-size: 0.82rem; width: 100%; border-collapse: collapse; }
.visitors-country-table th { padding: 0.5rem 0.75rem; font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); text-align: left; }
.visitors-country-table td { padding: 0.4rem 0.75rem; color: var(--text-secondary); white-space: nowrap; }
.visitors-country-table .country-bar { display: inline-block; height: 6px; border-radius: 3px; background: var(--accent); vertical-align: middle; margin-left: 0.4rem; }
.country-flag { font-size: 1.1em; margin-right: 0.3rem; }
.visitor-log-table th { overflow: visible !important; text-overflow: clip !important; white-space: normal !important; font-size: 0.75rem; line-height: 1.3; }
.visitor-log-table td { font-size: 0.82rem; overflow: visible !important; text-overflow: clip !important; white-space: nowrap; }
.sortable-th { cursor: pointer; user-select: none; }
.sortable-th:hover { color: var(--primary); }
.sortable-th .sort-wrap { display: inline-flex; align-items: center; gap: 3px; }
.sort-arrow { font-size: 0.65em; opacity: 0.3; flex-shrink: 0; }
.sortable-th.sort-active .sort-arrow { opacity: 1; color: var(--primary); }
.visitor-pages-cell { white-space: normal !important; overflow: visible !important; line-height: 1.5; }
.visitor-pages-cell .vp-tag { display: inline-block; background: var(--surface-2); border: 1px solid var(--border); border-radius: 4px; padding: 1px 6px; margin: 1px 2px; font-size: 0.73rem; color: var(--text-secondary); }
.visitor-pages-toggle { background: none; border: none; color: var(--primary); cursor: pointer; font-size: 0.73rem; padding: 1px 6px; display: inline-block; }
.visitor-pages-toggle:hover { text-decoration: underline; }
</style>

<script src="https://unpkg.com/chart.js@4.4.7/dist/chart.umd.min.js" crossorigin="anonymous"></script>
<script>
(function() {
  // ── Retry Chart.js loading if CDN fails ──
  function waitForChart(attempt) {
    attempt = attempt || 0;
    if (typeof Chart !== 'undefined') {
      initCharts();
      return;
    }
    if (attempt >= 3) {
      document.querySelectorAll('.chart-loading').forEach(function(el) {
        el.innerHTML = '<span style="color:var(--danger,#ef4444)">Failed to load Chart.js</span>';
      });
      console.error('Chart.js failed to load after retries');
      return;
    }
    // retry loading
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js';
    s.onload = function() { waitForChart(attempt + 1); };
    s.onerror = function() { setTimeout(function() { waitForChart(attempt + 1); }, 500); };
    document.head.appendChild(s);
  }

  function initCharts() {
    // ── Theme-aware colors ──
    var cs = getComputedStyle(document.documentElement);
    var chartColors = {
      accent: cs.getPropertyValue('--accent').trim() || '#a855f7',
      success: '#22c55e',
      danger: '#ef4444',
      warning: '#f59e0b',
      info: '#3b82f6',
      muted: cs.getPropertyValue('--text-muted').trim() || '#6b7280',
      border: cs.getPropertyValue('--border').trim() || '#333',
      text: cs.getPropertyValue('--text').trim() || '#e0e0e0',
      palette: ['#a855f7','#3b82f6','#22c55e','#f59e0b','#ef4444','#ec4899','#14b8a6','#f97316','#8b5cf6','#06b6d4']
    };

    Chart.defaults.color = chartColors.muted;
    Chart.defaults.borderColor = chartColors.border + '30';
    Chart.defaults.font.family = "'Inter', sans-serif";
    Chart.defaults.plugins.legend.labels.usePointStyle = true;
    Chart.defaults.plugins.legend.labels.pointStyle = 'circle';
    Chart.defaults.responsive = true;
    Chart.defaults.maintainAspectRatio = false;

    var chartInstances = {};
    var noDataLabel = t('admin_chart_no_data');

    function getDays() {
      return parseInt(document.getElementById('analyticsDays').value) || 14;
    }

    function formatDate(dateStr) {
      return window.formatTimestamp ? window.formatTimestamp(dateStr + 'T00:00:00', 'date') : new Date(dateStr + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    }

    function fetchData(endpoint) {
      var days = getDays();
      return fetch('/admin/analytics/' + endpoint + '?days=' + days)
        .then(function(r) {
          if (!r.ok) throw new Error('HTTP ' + r.status);
          return r.json();
        });
    }

    function destroyChart(id) {
      if (chartInstances[id]) { chartInstances[id].destroy(); delete chartInstances[id]; }
    }

    function hideLoading(wrapperId) {
      var wrap = document.getElementById(wrapperId);
      if (wrap) {
        var ld = wrap.querySelector('.chart-loading');
        if (ld) ld.remove();
        var nd = wrap.querySelector('.chart-no-data');
        if (nd) nd.remove();
      }
    }

    function showNoData(wrapperId) {
      var wrap = document.getElementById(wrapperId);
      if (!wrap) return;
      var ld = wrap.querySelector('.chart-loading');
      if (ld) ld.remove();
      // remove existing no-data if any
      var existing = wrap.querySelector('.chart-no-data');
      if (existing) existing.remove();
      var div = document.createElement('div');
      div.className = 'chart-no-data';
      div.innerHTML = '<i data-lucide="bar-chart-2"></i><span>' + noDataLabel + '</span>';
      wrap.appendChild(div);
      if (window.lucide) lucide.createIcons({ nodes: [div] });
    }

    function showError(wrapperId, msg) {
      var wrap = document.getElementById(wrapperId);
      if (!wrap) return;
      var ld = wrap.querySelector('.chart-loading');
      if (ld) ld.remove();
      var div = document.createElement('div');
      div.className = 'chart-error';
      div.innerHTML = '<span>Error: ' + msg + '</span>';
      wrap.appendChild(div);
    }

    // ── Page Views ──
    function loadPageViewsChart() {
      return fetchData('pageviews').then(function(data) {
        destroyChart('pageViews');
        hideLoading('wrapPageViews');
        var ctx = document.getElementById('chartPageViews');
        if (!ctx) return;
        if (!data || data.length === 0) { showNoData('wrapPageViews'); return; }
        chartInstances.pageViews = new Chart(ctx, {
          type: 'line',
          data: {
            labels: data.map(function(d) { return formatDate(d.day); }),
            datasets: [{
              label: t('admin_chart_views'),
              data: data.map(function(d) { return d.views; }),
              borderColor: chartColors.accent,
              backgroundColor: chartColors.accent + '20',
              borderWidth: 2.5, fill: true, tension: 0.4,
              pointRadius: 4, pointHoverRadius: 7,
              pointBackgroundColor: chartColors.accent
            }]
          },
          options: {
            plugins: { legend: { display: false } },
            scales: {
              y: { beginAtZero: true, ticks: { precision: 0 }, grid: { color: chartColors.border + '40' } },
              x: { grid: { display: false } }
            }
          }
        });
      }).catch(function(e) { showError('wrapPageViews', e.message); });
    }

    // ── Hourly Traffic ──
    function loadHourlyChart() {
      return fetchData('hourly-traffic').then(function(data) {
        destroyChart('hourly');
        hideLoading('wrapHourly');
        var ctx = document.getElementById('chartHourly');
        if (!ctx) return;
        var hasData = data && data.some(function(d) { return d.views > 0; });
        if (!hasData) { showNoData('wrapHourly'); return; }
        chartInstances.hourly = new Chart(ctx, {
          type: 'bar',
          data: {
            labels: data.map(function(d) { return String(d.hour).padStart(2, '0') + ':00'; }),
            datasets: [{
              label: t('admin_chart_views'),
              data: data.map(function(d) { return d.views; }),
              backgroundColor: data.map(function(_, i) { return chartColors.palette[i % chartColors.palette.length] + '70'; }),
              borderColor: data.map(function(_, i) { return chartColors.palette[i % chartColors.palette.length]; }),
              borderWidth: 1, borderRadius: 4
            }]
          },
          options: {
            plugins: { legend: { display: false } },
            scales: {
              y: { beginAtZero: true, ticks: { precision: 0 }, grid: { color: chartColors.border + '40' } },
              x: { grid: { display: false } }
            }
          }
        });
      }).catch(function(e) { showError('wrapHourly', e.message); });
    }

    // ── Popular Pages ──
    function loadPopularChart() {
      return fetchData('popular-pages').then(function(data) {
        destroyChart('popular');
        hideLoading('wrapPopular');
        var ctx = document.getElementById('chartPopular');
        if (!ctx) return;
        if (!data || data.length === 0) { showNoData('wrapPopular'); return; }
        chartInstances.popular = new Chart(ctx, {
          type: 'bar',
          data: {
            labels: data.map(function(d) { return d.path.length > 25 ? d.path.substring(0, 25) + '\u2026' : d.path; }),
            datasets: [{
              label: t('admin_chart_views'),
              data: data.map(function(d) { return d.views; }),
              backgroundColor: chartColors.info + '70',
              borderColor: chartColors.info,
              borderWidth: 1, borderRadius: 4
            }]
          },
          options: {
            indexAxis: 'y',
            plugins: { legend: { display: false } },
            scales: {
              x: { beginAtZero: true, ticks: { precision: 0 }, grid: { color: chartColors.border + '40' } },
              y: { grid: { display: false }, ticks: { color: chartColors.text, font: { size: 11 } } }
            }
          }
        });
      }).catch(function(e) { showError('wrapPopular', e.message); });
    }

    // ── Server Uptime (daily breakdown per server) ──
    function loadUptimeChart() {
      return fetchData('server-uptime').then(function(data) {
        destroyChart('uptime');
        hideLoading('wrapUptime');
        var ctx = document.getElementById('chartUptime');
        if (!ctx) return;
        if (!data || !data.servers || data.servers.length === 0) { showNoData('wrapUptime'); return; }

        var datasets = data.servers.map(function(srv, i) {
          var color = chartColors.palette[i % chartColors.palette.length];
          return {
            label: srv.name,
            data: srv.data,
            borderColor: color,
            backgroundColor: color + '20',
            borderWidth: 2,
            fill: false,
            tension: 0.3,
            pointRadius: 3,
            pointHoverRadius: 6,
            spanGaps: true
          };
        });

        chartInstances.uptime = new Chart(ctx, {
          type: 'line',
          data: {
            labels: data.days.map(function(d) { return formatDate(d); }),
            datasets: datasets
          },
          options: {
            plugins: {
              legend: { position: 'top', labels: { color: chartColors.text, font: { size: 11 }, boxWidth: 12 } },
              tooltip: { callbacks: { label: function(ctx) { return ctx.dataset.label + ': ' + ctx.parsed.y + '%'; } } }
            },
            scales: {
              y: { beginAtZero: true, max: 100, ticks: { callback: function(v) { return v + '%'; }, color: chartColors.text }, grid: { color: chartColors.border + '40' } },
              x: { grid: { display: false }, ticks: { color: chartColors.text } }
            }
          }
        });
      }).catch(function(e) { showError('wrapUptime', e.message); });
    }

    // ── Chat Activity ──
    function loadChatChart() {
      return fetchData('chat-activity').then(function(data) {
        destroyChart('chat');
        hideLoading('wrapChat');
        var ctx = document.getElementById('chartChat');
        if (!ctx) return;
        if (!data || data.length === 0) { showNoData('wrapChat'); return; }
        chartInstances.chat = new Chart(ctx, {
          type: 'bar',
          data: {
            labels: data.map(function(d) { return formatDate(d.day); }),
            datasets: [{
              label: t('admin_chart_messages'),
              data: data.map(function(d) { return d.messages; }),
              backgroundColor: chartColors.success + '60',
              borderColor: chartColors.success,
              borderWidth: 1, borderRadius: 4
            }]
          },
          options: {
            plugins: { legend: { display: false } },
            scales: {
              y: { beginAtZero: true, ticks: { precision: 0 }, grid: { color: chartColors.border + '40' } },
              x: { grid: { display: false } }
            }
          }
        });
      }).catch(function(e) { showError('wrapChat', e.message); });
    }

    // ── Server Timeline ──
    function loadTimelineChart() {
      return fetchData('server-timeline').then(function(data) {
        destroyChart('timeline');
        hideLoading('wrapTimeline');
        var ctx = document.getElementById('chartTimeline');
        if (!ctx) return;
        if (!data || data.length === 0) { showNoData('wrapTimeline'); return; }
        chartInstances.timeline = new Chart(ctx, {
          type: 'line',
          data: {
            labels: data.map(function(d) { return formatDate(d.day); }),
            datasets: [
              {
                label: t('admin_dashboard_online'),
                data: data.map(function(d) { return d.online; }),
                borderColor: chartColors.success,
                backgroundColor: chartColors.success + '25',
                borderWidth: 2, fill: true, tension: 0.3, pointRadius: 2
              },
              {
                label: t('admin_dashboard_offline'),
                data: data.map(function(d) { return d.offline; }),
                borderColor: chartColors.danger,
                backgroundColor: chartColors.danger + '25',
                borderWidth: 2, fill: true, tension: 0.3, pointRadius: 2
              }
            ]
          },
          options: {
            plugins: { legend: { position: 'top', labels: { color: chartColors.text } } },
            scales: {
              y: { beginAtZero: true, stacked: true, ticks: { precision: 0 }, grid: { color: chartColors.border + '40' } },
              x: { grid: { display: false } }
            }
          }
        });
      }).catch(function(e) { showError('wrapTimeline', e.message); });
    }

    // ── Country code → flag emoji ──
    function countryFlag(code) {
      if (!code || code === 'Unknown') return '🏳️';
      var chars = code.toUpperCase().split('').map(function(c) { return String.fromCodePoint(0x1F1E6 - 65 + c.charCodeAt(0)); });
      return chars.join('');
    }

    // ── Countries Doughnut ──
    function loadCountriesChart() {
      return fetchData('countries').then(function(data) {
        destroyChart('countries');
        hideLoading('wrapCountries');
        var ctx = document.getElementById('chartCountries');
        if (!ctx) return;
        if (!data || data.length === 0) { showNoData('wrapCountries'); return; }
        chartInstances.countries = new Chart(ctx, {
          type: 'doughnut',
          data: {
            labels: data.map(function(d) { return countryFlag(d.country) + ' ' + d.country; }),
            datasets: [{
              data: data.map(function(d) { return d.visitors; }),
              backgroundColor: data.map(function(_, i) { return chartColors.palette[i % chartColors.palette.length] + 'CC'; }),
              borderColor: 'transparent',
              borderWidth: 2
            }]
          },
          options: {
            cutout: '55%',
            plugins: {
              legend: { position: 'right', labels: { color: chartColors.text, font: { size: 11 }, padding: 8, boxWidth: 14 } }
            }
          }
        });

        // Also fill country table
        var table = document.getElementById('countryTable');
        var tbody = table ? table.querySelector('tbody') : null;
        if (tbody) {
          var total = data.reduce(function(s, d) { return s + d.visitors; }, 0);
          tbody.innerHTML = data.map(function(d) {
            var pct = total > 0 ? (d.visitors / total * 100).toFixed(1) : 0;
            var barW = total > 0 ? Math.round(d.visitors / total * 80) : 0;
            return '<tr><td><span class="country-flag">' + countryFlag(d.country) + '</span>' + d.country + '</td>' +
                   '<td>' + d.visitors + '</td>' +
                   '<td>' + pct + '%<span class="country-bar" style="width:' + barW + 'px"></span></td></tr>';
          }).join('');
          table.style.display = '';
          var ld = document.getElementById('wrapCountryTable');
          if (ld) { var l = ld.querySelector('.chart-loading'); if (l) l.remove(); }
        }
      }).catch(function(e) { showError('wrapCountries', e.message); });
    }

    // ── Visitor Log ──
    var _visitorPage = 1;
    var _visitorSort = 'visits';
    var _visitorDir = 'desc';

    function renderPages(pages) {
      if (!pages || pages.length === 0) return '-';
      var show = 5;
      var visible = pages.slice(0, show);
      var hidden = pages.slice(show);
      var html = visible.map(function(p) { return '<span class="vp-tag">' + p + '</span>'; }).join('');
      if (hidden.length > 0) {
        var uid = 'vp_' + Math.random().toString(36).substr(2, 6);
        var hiddenHtml = hidden.map(function(p) { return '<span class="vp-tag">' + p + '</span>'; }).join('');
        var tMore = t('admin_visitor_more');
        var tCollapse = t('admin_visitor_collapse');
        html += '<span id="' + uid + '" style="display:none">' + hiddenHtml + '</span>';
        html += '<button class="visitor-pages-toggle" onclick="var el=document.getElementById(\'' + uid + '\');if(el.style.display===\'none\'){el.style.display=\'\';this.textContent=\'▲ ' + tCollapse + '\';}else{el.style.display=\'none\';this.textContent=\'+ ' + hidden.length + ' ' + tMore + '\';}">+ ' + hidden.length + ' ' + tMore + '</button>';
      }
      return html;
    }

    function loadVisitorLog(page) {
      page = page || 1;
      _visitorPage = page;
      var days = getDays();
      fetch('/admin/analytics/visitors?days=' + days + '&page=' + page + '&sort=' + _visitorSort + '&dir=' + _visitorDir)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var tbody = document.getElementById('visitorTableBody');
          if (!tbody) return;
          if (!data.visitors || data.visitors.length === 0) {
            var noDataText = t('admin_visitor_nodata');
            tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--text-muted)">' + noDataText + '</td></tr>';
            return;
          }
          tbody.innerHTML = data.visitors.map(function(v) {
            var firstVisit = window.formatTimestamp ? window.formatTimestamp(v.first_visit, 'datetime') : v.first_visit;
            var lastVisit = window.formatTimestamp ? window.formatTimestamp(v.last_visit, 'datetime') : v.last_visit;
            return '<tr>' +
              '<td class="mono">' + v.ip + '</td>' +
              '<td style="text-align:center"><span class="country-flag">' + countryFlag(v.country) + '</span>' + v.country + '</td>' +
              '<td style="text-align:center">' + v.total_views + '</td>' +
              '<td style="text-align:center">' + v.unique_pages + '</td>' +
              '<td>' + firstVisit + '</td>' +
              '<td>' + lastVisit + '</td>' +
              '<td class="visitor-pages-cell">' + renderPages(v.pages) + '</td>' +
              '</tr>';
          }).join('');

          // Pagination
          var info = document.getElementById('visitorPageInfo');
          var prev = document.getElementById('prevPageBtn');
          var next = document.getElementById('nextPageBtn');
          if (info) info.textContent = data.page + ' / ' + data.totalPages;
          if (prev) prev.disabled = data.page <= 1;
          if (next) next.disabled = data.page >= data.totalPages;

          // Update sort arrows
          document.querySelectorAll('.sortable-th').forEach(function(th) {
            var arrow = th.querySelector('.sort-arrow');
            if (th.dataset.sort === _visitorSort) {
              th.classList.add('sort-active');
              arrow.textContent = _visitorDir === 'asc' ? '▲' : '▼';
            } else {
              th.classList.remove('sort-active');
              arrow.textContent = '▽';
            }
          });
        })
        .catch(function() {});
    }

    // Sorting — click on column headers
    document.querySelectorAll('.sortable-th').forEach(function(th) {
      th.addEventListener('click', function() {
        var col = th.dataset.sort;
        if (_visitorSort === col) {
          _visitorDir = _visitorDir === 'desc' ? 'asc' : 'desc';
        } else {
          _visitorSort = col;
          _visitorDir = 'desc';
        }
        loadVisitorLog(1);
      });
    });

    // Pagination buttons
    var prevBtn = document.getElementById('prevPageBtn');
    var nextBtn = document.getElementById('nextPageBtn');
    if (prevBtn) prevBtn.addEventListener('click', function() { if (_visitorPage > 1) loadVisitorLog(_visitorPage - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function() { loadVisitorLog(_visitorPage + 1); });

    // ── Load All ──
    window.loadAllCharts = function() {
      var btn = document.getElementById('refreshChartsBtn');
      if (btn) btn.disabled = true;

      // re-show loading indicators
      document.querySelectorAll('.chart-no-data, .chart-error').forEach(function(el) { el.remove(); });
      document.querySelectorAll('.chart-body').forEach(function(wrap) {
        if (!wrap.querySelector('.chart-loading')) {
          var ld = document.createElement('div');
          ld.className = 'chart-loading';
          ld.textContent = 'Loading...';
          wrap.appendChild(ld);
        }
      });

      Promise.all([
        loadPageViewsChart(),
        loadHourlyChart(),
        loadPopularChart(),
        loadUptimeChart(),
        loadChatChart(),
        loadTimelineChart(),
        loadCountriesChart()
      ]).then(function() {
        loadVisitorLog(1);
        if (btn) btn.disabled = false;
      }).catch(function(e) {
        console.error('Charts error:', e);
        if (btn) btn.disabled = false;
      });
    };

    // Period selector
    var periodSelect = document.getElementById('analyticsDays');
    if (periodSelect) periodSelect.addEventListener('change', window.loadAllCharts);

    // Initial load
    setTimeout(window.loadAllCharts, 100);
  }

  // Start init
  waitForChart(0);
})();
</script>

<%- include('../partials/footer') %>
