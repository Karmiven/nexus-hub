<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <title><%= title %> | <%= typeof navbarTitle !== 'undefined' ? navbarTitle : 'NexusHub' %></title>
  <script>
    // Apply saved theme IMMEDIATELY — before any CSS loads — to prevent white flash
    (function(){
      var t = localStorage.getItem('theme') || 'dark';
      var lang = localStorage.getItem('language') || 'en';
      document.documentElement.setAttribute('data-theme', t);
      window.__savedTheme = t;
      window.__savedLang = lang;
      // Set bg color directly on <html> so browser never shows white during CSS load.
      // Cleared after theme CSS loads so theme variables take over normally.
      var bgMap = {
        'dark':                '#0c0e14',
        'light':               '#f6f5f1',
        'cyberpunk-purple':    '#08010f',
        'matrix-green':        '#000000',
        'retro-90s-vaporwave': '#150a28',
        'vampire':             '#140e0c'
      };
      var bg = bgMap[t] || '#0c0e14';
      document.documentElement.style.backgroundColor = bg;
      document.documentElement.style.colorScheme = (t === 'light') ? 'light' : 'dark';
      // Remove inline override once theme CSS is loaded (so CSS variables take full control)
      window.__clearBgOverride = function() {
        document.documentElement.style.backgroundColor = '';
      };
    })();
  </script>
  <link rel="stylesheet" href="/css/style.css?v=<%= v %>">
  <link rel="stylesheet" id="theme-stylesheet" href="/css/themes/dark.css?v=<%= v %>">
  <link rel="stylesheet" href="/css/mobile.css?v=<%= v %>">
  <link rel="stylesheet" href="/css/desktop.css?v=<%= v %>">
  <script>
    // Update theme stylesheet href ASAP (after <link> exists)
    (function(){
      var t = window.__savedTheme || 'dark';
      var link = document.getElementById('theme-stylesheet');
      if (link) link.href = '/css/themes/' + t + '.css?v=<%= v %>';
    })();
  </script>
  <script src="https://unpkg.com/lucide@0.454.0/dist/umd/lucide.min.js" crossorigin="anonymous"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Exo+2:wght@400;600;700;900&family=Inter:wght@300;400;500;600;700&family=UnifrakturCook:wght@700&family=VT323&display=swap" rel="stylesheet">
  <script src="/js/translations.js?v=<%= v %>"></script>
  <script src="/js/theme-effects.js?v=<%= v %>"></script>
  <script>
    window.SITE_TIMEZONE = '<%= typeof siteTimezone !== "undefined" ? siteTimezone : "Europe/Moscow" %>';
  </script>
  <style>
    /* ========== Anti-FOUC: hide page until theme CSS is loaded ========== */
    /* Body is invisible initially; JS reveals it once everything is ready */
    body {
      visibility: hidden;
    }
    body.page-rendered {
      visibility: visible;
    }

    /* Suppress all transitions during SPA content swap to prevent white flash */
    body.spa-swapping * {
      transition: none !important;
    }

    /* Content area fades in for SPA-like feel; navbar stays solid */
    .main-content {
      opacity: 0;
      transform: translateY(6px);
    }
    .main-content.content-ready {
      opacity: 1;
      transform: translateY(0);
      transition: opacity 0.3s ease, transform 0.3s ease;
    }
    .footer {
      opacity: 0;
    }
    .footer.content-ready {
      opacity: 1;
      transition: opacity 0.3s ease 0.05s;
    }

    /* Fix logo icon size — prevent layout shift when lucide replaces <i> with <svg> */
    .logo-icon {
      width: 1.3rem;
      height: 1.3rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .logo-icon i[data-lucide] {
      width: 1.3rem;
      height: 1.3rem;
      display: block;
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <div class="nav-container">
      <a href="/" class="nav-logo">
        <span class="logo-icon"><i data-lucide="zap"></i></span>
        <span class="logo-text"><%= typeof navbarTitle !== 'undefined' ? navbarTitle : 'NexusHub' %></span>
      </a>
      <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav-links" id="navLinks">
        <li class="nav-item nav-item-home"><a href="/" class="nav-link" data-i18n="nav_home">Home</a></li>
        <li class="nav-item nav-item-servers"><a href="/servers" class="nav-link" data-i18n="nav_servers">Servers</a></li>
        <li class="nav-item nav-item-community"><a href="/community" class="nav-link" data-i18n="nav_community">Community</a></li>
        <% if (monitoringPublic || (user && user.role === 'admin')) { %>
        <li class="nav-item nav-item-monitoring"><a href="/monitoring/dashboard" class="nav-link" data-i18n="nav_monitoring">Monitoring</a></li>
        <% } %>

        <li class="nav-item nav-item-admin <%= (user && user.role === 'admin') ? '' : 'nav-item-placeholder' %>">
          <% if (user && user.role === 'admin') { %>
            <a href="/admin" class="nav-link nav-admin" data-i18n="nav_admin">Admin</a>
          <% } %>
        </li>

        <li class="nav-item nav-item-auth">
          <% if (user) { %>
            <form action="/auth/logout" method="POST" style="display:inline;margin:0;padding:0;">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="nav-link btn-nav-logout" data-i18n="nav_logout">Logout</button>
            </form>
          <% } else { %>
            <a href="/auth/login" class="nav-link btn-nav-outline" data-i18n="nav_login">Login</a>
          <% } %>
        </li>

        <li class="nav-item nav-item-theme-lang">
          <select class="theme-selector" id="themeSwitcher" aria-label="Select theme">
            <option value="dark">Dark</option>
            <option value="light">Light</option>
            <option value="cyberpunk-purple">Cyberpunk</option>
            <option value="matrix-green">Matrix</option>
            <option value="retro-90s-vaporwave">Retro 90s</option>
            <option value="vampire">Vampire</option>
          </select>

          <select class="language-selector" id="languageSelector" aria-label="Select language">
            <option value="en">ENG</option>
            <option value="ru">RUS</option>
          </select>
        </li>
      </ul>
    </div>
  </nav>
  <script>
    // Pre-set selectors SYNCHRONOUSLY before paint
    (function(){
      var ts = document.getElementById('themeSwitcher');
      if (ts && window.__savedTheme) ts.value = window.__savedTheme;
      var ls = document.getElementById('languageSelector');
      if (ls && window.__savedLang) ls.value = window.__savedLang;
    })();
  </script>

  <% if (success && success.length > 0) { %>
    <div class="flash flash-success" data-i18n="<%= success[0] %>"><%= success[0] %></div>
  <% } %>
  <% if (error && error.length > 0) { %>
    <div class="flash flash-error" data-i18n="<%= error[0] %>"><%= error[0] %></div>
  <% } %>

  <main class="main-content">
